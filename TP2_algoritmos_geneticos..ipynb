      },
      "source": [
        "## 2. Desarrollo del Modelo Evolutivo y Simulación de Asignación Espacio-Temporal"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "solucion-algoritmo-genetico"
      },
      "execution_count": null,
      "outputs": [],
      "source": [
        "import pygad\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ==========================================================================\n",
        "# 1. MODELADO DE DATOS E INFRAESTRUCTURA DEL PROYECTO\n",
        "# ==========================================================================\n",
        "TAREAS_OBRA = {\n",
        "    0: (5, 4),   # (Duración en días, Operarios necesarios)\n",
        "    1: (7, 6),\n",
        "    2: (4, 5),\n",
        "    3: (6, 3),\n",
        "    4: (5, 4),\n",
        "    5: (4, 3),\n",
        "    6: (3, 2),\n",
        "    7: (2, 3),\n",
        "    8: (4, 2),\n",
        "    9: (2, 2)\n",
        "}\n",
        "\n",
        "DEPENDENCIAS = {\n",
        "    0: [],\n",
        "    1: [0],\n",
        "    2: [1],\n",
        "    3: [1],\n",
        "    4: [3],\n",
        "    5: [0],\n",
        "    6: [4],\n",
        "    7: [1, 5],\n",
        "    8: [3],\n",
        "    9: [7, 8]\n",
        "}\n",
        "\n",
        "MAX_OPERARIOS = 10\n",
        "NUM_TAREAS = len(TAREAS_OBRA)\n",
        "\n",
        "# ==========================================================================\n",
        "# 2. DECODIFICADOR HEURÍSTICO DE CRONOGRAMAS (CONSTRUCTOR DE CALENDARIOS)\n",
        "# ==========================================================================\n",
        "def construir_cronograma_legal(orden_prioridad):\n",
        "    \"\"\"Toma una permutación de tareas y construye un cronograma válido sin romper restricciones.\"\"\"\n",
        "    dias_inicio = {} \n",
        "    dias_fin = {}\n",
        "    perfil_operarios_diario = np.zeros(200, dtype=int)  # Vector temporal extendido\n",
        "    \n",
        "    for tarea in orden_prioridad:\n",
        "        tarea = int(tarea)\n",
        "        duracion, operarios_requeridos = TAREAS_OBRA[tarea]\n",
        "        \n",
        "        # Calcular el día más temprano basado estrictamente en el fin de sus prerrequisitos\n",
        "        dia_base_precedencias = 0\n",
        "        if DEPENDENCIAS[tarea]:\n",
        "            dia_base_precedencias = max(dias_fin[pre] for pre in DEPENDENCIAS[tarea])\n",
        "        \n",
        "        # Buscar la ventana temporal libre que cuente con suficiente capacidad de operarios\n",
        "        dia_actual = dia_base_precedencias\n",
        "        while True:\n",
        "            ventana_tiempo = perfil_operarios_diario[dia_actual : dia_actual + duracion]\n",
        "            # Verificar si añadir esta tarea viola el tope de la cuadrilla\n",
        "            if np.all(ventana_tiempo + operarios_requeridos <= MAX_OPERARIOS):\n",
        "                break\n",
        "            dia_actual += 1\n",
        "            \n",
        "        # Asignar de forma definitiva las fechas y actualizar el vector de carga del personal\n",
        "        dias_inicio[tarea] = dia_actual\n",
        "        dias_fin[tarea] = dia_actual + duracion\n",
        "        perfil_operarios_diario[dia_actual : dia_actual + duracion] += operarios_requeridos\n",
        "        \n",
        "    makespan = max(dias_fin.values())\n",
        "    return makespan, dias_inicio, perfil_operarios_diario\n",
        "\n",
        "# ==========================================================================\n",
        "# 3. FUNCIÓN DE APTITUD (FITNESS PURO)\n",
        "# ==========================================================================\n",
        "def fitness_func(ga_instance, solution, solution_idx):\n",
        "    # Como el constructor garantiza la legalidad de la solución,\n",
        "    # el fitness es simplemente la maximización del inverso del tiempo total.\n",
        "    makespan, _, _ = construir_cronograma_legal(solution)\n",
        "    return 1.0 / makespan\n",
        "\n",
        "# ==========================================================================\n",
        "# 4. CONFIGURACIÓN E INICIALIZACIÓN DEL PROCESO EVOLUTIVO\n",
        "# ==========================================================================\n",
        "ga_instance = pygad.GA(\n",
        "    num_generations=250,           # Requiere menos épocas debido a la eficiencia del genotipo\n",
        "    num_parents_mating=30,\n",
        "    fitness_func=fitness_func,\n",
        "    sol_per_pop=150,\n",
        "    num_genes=NUM_TAREAS,\n",
        "    gene_type=int,\n",
        "    # Forzamos que los genes iniciales sean una secuencia ordenada que luego mutará en permutaciones\n",
        "    gene_space=range(0, NUM_TAREAS),\n",
        "    allow_duplicate_genes=False,   # Garantiza que actúe bajo operador de combinación/permutación pura\n",
        "    parent_selection_type=\"tournament\",\n",
        "    K_tournament=3,\n",
        "    mutation_type=\"scramble\",      # Operador de mutación ideal para optimizar secuencias ordenadas\n",
        "    mutation_probability=0.20,\n",
        "    random_seed=101\n",
        ")\n",
        "\n",
        "print(\"🚀 Buscando la secuencia óptima de prioridades industriales...\")\n",
        "ga_instance.run()\n",
        "print(\"🛑 Proceso de optimización por permutación completado.\\n\")\n",
        "\n",
        "# ==========================================================================\n",
        "# 5. RENDIMIENTO Y VISUALIZACIÓN MULTI-GRÁFICA\n",
        "# ==========================================================================\n",
        "mejores_genes, fitness_final, _ = ga_instance.best_solution()\n",
        "makespan_final, mapa_calendario, carga_personal = construir_cronograma_legal(mejores_genes)\n",
        "\n",
        "print(\"==================================================================\")\n",
        "print(\"📊 CONFIGURACIÓN LOGÍSTICA ENCONTRADA\")\n",
        "print(\"==================================================================\")\n",
        "print(f\"📌 Vector Guía de Prioridad (Cromosoma): {mejores_genes}\")\n",
        "print(f\"⏱️ Eficiencia de Obra (Makespan): {makespan_final} días\")\n",
        "\n",
        "print(\"\\n📅 Fechas de Inicio de Tareas Deducidas de Forma Segura:\")\n",
        "cronograma_ordenado = sorted(mapa_calendario.items())\n",
        "for tarea_id, dia_in in cronograma_ordenado:\n",
        "    d_fin = dia_in + TAREAS_OBRA[tarea_id][0]\n",
        "    print(f\"  • Tarea {tarea_id} -> Inicia Jornada: {dia_in:02d} | Finaliza Jornada: {d_fin:02d} [Duración: {TAREAS_OBRA[tarea_id][0]} días | Operarios: {TAREAS_OBRA[tarea_id][1]}]\")\n",
        "\n",
        "# Generación de gráficos comparativos combinados\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(15, 5))\n",
        "\n",
        "# Gráfico izquierda: Curva de convergencia clásica\n",
        "ax1.plot(ga_instance.best_solutions_fitness, color=\"#2ca02c\", linewidth=2)\n",
        "ax1.set_title(\"Evolución del Fitness (Optimización por Permutación)\")\n",
        "ax1.set_xlabel(\"Generaciones\")\n",
        "ax1.set_ylabel(\"Fitness (1/Makespan)\")\n",
        "ax1.grid(True, linestyle=\"--\", alpha=0.6)\n",
        "\n",
        "# Nuevo Gráfico derecha: Perfil de Carga e Histograma de Personal por día de obra\n",
        "dias_reales = range(0, makespan_final)\n",
        "ax2.step(dias_reales, carga_personal[:makespan_final], where='post', color=\"#1f77b4\", linewidth=2.5, label=\"Operarios Activos\")\n",
        "ax2.axhline(y=MAX_OPERARIOS, color='r', linestyle='--', linewidth=1.5, label=\"Capacidad Máxima (10)\")\n",
        "ax2.set_title(\"Perfil de Uso y Carga de Mano de Obra Diaria\")\n",
        "ax2.set_xlabel(\"Día de la Obra\")\n",
        "ax2.set_ylabel(\"Cantidad de Operarios en Predio\")\n",
        "ax2.set_ylim(0, 12)\n",
        "ax2.grid(True, linestyle=\"--\", alpha=0.6)\n",
        "ax2.legend(loc=\"lower left\")\n",
        "\n",
        plt.tight_layout()\n",
        plt.show()"
      ]
    },
    {
