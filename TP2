from experta import *

# 1. Definición de Hechos Estructurados
class LecturaSensor(Fact):
    """Representa las lecturas individuales enviadas por los sensores de la obra."""
    pass

class EvaluacionRiesgo(Fact):
    """Almacena el estado final deducido por el sistema."""
    pass

# 2. Motor de Inferencia Optimizado
class MotorSeguridad(KnowledgeEngine):

    # REGLA 1: RIESGO CRÍTICO (Prioridad Absoluta)
    # Se dispara de inmediato si el viento supera los 60 km/h O si hay grietas.
    @Rule(
        OR(
            LecturaSensor(tipo="viento", valor=MATCH.v & P(lambda v: v > 60)),
            LecturaSensor(tipo="grietas", valor=True)
        ),
        salience=100
    )
    def detectar_riesgo_critico(self):
        print("⚠️ [EMERGENCIA DE DETECCIÓN] Condiciones críticas identificadas.")
        print("RESULTADO: RIESGO CRÍTICO DETECTADO.")
        print("ACCIÓN: PARO TOTAL DE OBRA. Activando protocolos de evacuación inmediata.\n")
        self.declare(EvaluacionRiesgo(estado="critico"))

    # REGLA 2: RIESGO MODERADO (Evaluación Intermedia)
    # Se evalúa si no se ha declarado un riesgo crítico en el sistema.
    @Rule(
        NOT(EvaluacionRiesgo(estado="critico")),
        OR(
            LecturaSensor(tipo="viento", valor=MATCH.v & P(lambda v: 40 <= v <= 60)),
            LecturaSensor(tipo="humedad_extrema", valor=True)
        ),
        salience=50
    )
    def detectar_riesgo_moderado(self):
        print("⚠️ [PRECAUCIÓN] Factores climáticos o del terreno inestables.")
        print("RESULTADO: RIESGO MODERADO.")
        print("ACCIÓN: ALERTA AMARILLA. Suspender maniobras de altura e izaje pesado.\n")
        self.declare(EvaluacionRiesgo(estado="moderado"))

    # REGLA 3: BAJO RIESGO (Operación Segura)
    # Solo se activa si todos los parámetros están dentro de los rangos ideales.
    @Rule(
        LecturaSensor(tipo="viento", valor=MATCH.v & P(lambda v: v < 40)),
        LecturaSensor(tipo="grietas", valor=False),
        LecturaSensor(tipo="humedad_extrema", valor=False),
        salience=10
    )
    def detectar_bajo_riesgo(self):
        print("✅ [ESTADO OPERATIVO] Todos los parámetros bajo control.")
        print("RESULTADO: BAJO RIESGO.")
        print("ACCIÓN: OPERACIÓN NORMAL. Continuar con el cronograma planificado.\n")
        self.declare(EvaluacionRiesgo(estado="bajo"))

# --- PRUEBA Y CONTROL DE SIMULACIÓN ---
engine = MotorSeguridad()
engine.reset()

print("--- Cargando datos de sensores en tiempo real ---")
