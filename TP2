from constraint import *

# 1. Definición de Funciones de Restricción Explicitas (Reglas de Negocio)
def restriccion_base_grua(zona_grua):
    """La Grúa Torre exige suelo firme estructural."""
    return zona_grua == "Zona_Estable"

def restriccion_dimensiones_excavadora(zona_excavadora):
    """La Excavadora supera los límites volumétricos de espacios confinados."""
    return zona_excavadora != "Zona_Estrecha"

def verificar_congestion_logistica(zona_hormigonera, zona_grua):
    """Evita el embotellamiento de camiones mezcladores y de carga."""
    return zona_hormigonera != zona_grua

def resolver_planificación_obra():
    # Inicialización del espacio del problema (CSP)
    constructor_plan = Problem()

    # 2. Definición de Variables y sus respectivos Dominios
    equipos = ["Grua_Torre", "Excavadora", "Hormigonera"]
    zonas_obra = ["Zona_Estable", "Zona_Estrecha", "Zona_Comun"]
    
    constructor_plan.addVariables(equipos, zonas_obra)

    # 3. Inyección del Grafo de Restricciones
    # Restricción Física: No colisión (Unicidad)
    constructor_plan.addConstraint(AllDifferentConstraint())

    # Restricciones de Seguridad e Infraestructura
    constructor_plan.addConstraint(restriccion_base_grua, ["Grua_Torre"])
    constructor_plan.addConstraint(restriccion_dimensiones_excavadora, ["Excavadora"])
    constructor_plan.addConstraint(verificar_congestion_logistica, ["Hormigonera", "Grua_Torre"])

    # 4. Procesamiento y Poda del Árbol de Búsqueda
    soluciones_validas = constructor_plan.getSolutions()

    # 5. Output formalizado
    print(f" Análisis de Combinatorias Finalizado.")
    print(f"Se identificó {len(soluciones_validas)} distribución óptima que cumple el 100% de las normativas de seguridad:\n")
    
    for indice, asignacion in enumerate(soluciones_validas, 1):
        print(f" Plan de Disposición Operativa N°{indice}:")
        for maquina, zona in asignacion.items():
            print(f"  ▪️ {maquina.replace('_', ' ')}  Asignada a: {zona.replace('_', ' ')}")

# Ejecutar el planeador espacial
resolver_planificación_obra()

# Ejecución del motor logico
engine.run()
